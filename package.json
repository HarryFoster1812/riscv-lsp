{
  "name": "risc-v-lsp",
  "displayName": "RISC-V lsp",
  "publisher": "VukStojkovic",
  "repository": {
    "type": "git",
    "url": "https://github.com/V-Stojkovic/riscv-lsp"
  },
  "icon": "images/icon.png",
  "version": "1.2.1",
  "description": "LSP and language support for RISC-V assembly",
  "main": "./out/client.js",
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onLanguage:riscv"
  ],
  "contributes": {
    "languages": [
      {
        "id": "riscv",
        "aliases": [
          "RISC-V",
          "riscv"
        ],
        "extensions": [
          ".s",
          ".asm",
          ".S"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "riscv",
        "scopeName": "source.riscv",
        "path": "./syntaxes/riscv.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "test": "jest"
  },
  "keywords": [
    "riscv",
    "assembly",
    "lsp"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.80.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.5.0"
  }
}
